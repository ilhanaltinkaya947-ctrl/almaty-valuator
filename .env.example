# ══════════════════════════════════════
# Almaty Valuator 2026 — Environment
# ══════════════════════════════════════
# Copy to .env.local and fill in values
# NEVER commit .env.local to git

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── WhatsApp Business API (Meta) ──
WHATSAPP_TOKEN=your-permanent-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-string
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_ADMIN_CHAT_ID=your-admin-chat-id

# ── n8n Automation ──
AUTOMATION_API_KEY=your-strong-random-key-for-n8n
N8N_ENCRYPTION_KEY=your-n8n-encryption-key
CLAUDE_API_KEY=your-claude-api-key-for-n8n-ai

# ── Google Maps (static maps in PDF) ──
GOOGLE_MAPS_API_KEY=your-maps-api-key

# ── Sentry ──
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ── App Config ──
NEXT_PUBLIC_APP_URL=https://valuator.yourdomain.kz
NODE_ENV=development
